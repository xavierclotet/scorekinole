rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper: check if user is an admin via Firestore
    function isAdmin() {
      return request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Helper: check if user is the owner or an admin of the given tournament
    function isTournamentOwnerOrAdmin(tournamentId) {
      let t = firestore.get(/databases/(default)/documents/tournaments/$(tournamentId)).data;
      return request.auth != null
          && (request.auth.uid == t.ownerId
              || (t.adminIds is list && request.auth.uid in t.adminIds));
    }

    // ---------------------------------------------------------------
    // User avatars
    // ---------------------------------------------------------------
    match /users/{userId}/avatar.jpg {
      // Anyone can read avatars (used on rankings, tournament pages, etc.)
      allow read: if true;

      // Owner uploads their own avatar (exclude SVG via explicit mime types)
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|jpg|png|webp|gif)');

      // Platform admin can upload avatar for any user
      allow write: if isAdmin()
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|jpg|png|webp|gif)');

      // Owner or admin can delete avatar
      allow delete: if request.auth != null
                    && (request.auth.uid == userId || isAdmin());
    }

    // ---------------------------------------------------------------
    // Tournament photos
    // ---------------------------------------------------------------
    match /tournaments/{tournamentId}/{allPaths=**} {
      // Anyone can read tournament photos (public tournament pages)
      allow read: if true;

      // Only the tournament owner or an admin of that specific tournament can upload.
      // SVG is excluded to prevent polyglot/script injection attacks.
      allow write: if isTournamentOwnerOrAdmin(tournamentId)
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|jpg|png|webp|gif)');
    }
  }
}
