rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper: check if user is admin via Firestore
    function isAdmin() {
      return request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // User avatars - owner or admin can write, anyone can read
    match /users/{userId}/avatar.jpg {
      // Anyone can read avatars (for rankings, tournament pages, etc.)
      allow read: if true;

      // Owner can upload their avatar
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024  // Max 2MB
                   && request.resource.contentType.matches('image/.*');

      // Admin can upload avatar for any user
      allow write: if isAdmin()
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');

      // Owner or admin can delete avatar
      allow delete: if request.auth != null
                    && (request.auth.uid == userId || isAdmin());
    }

    // Tournament photos (future use)
    match /tournaments/{tournamentId}/{allPaths=**} {
      // Anyone can read tournament photos
      allow read: if true;

      // Only authenticated users can write (will add admin check later)
      allow write: if request.auth != null
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
